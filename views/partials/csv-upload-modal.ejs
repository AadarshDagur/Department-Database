<div class="modal fade" id="csvUploadModal" tabindex="-1" aria-labelledby="csvUploadModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background: var(--iit-blue); color: #fff;">
        <h5 class="modal-title" id="csvUploadModalLabel"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Upload CSV &mdash; <%= entityType.charAt(0).toUpperCase() + entityType.slice(1) %></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/<%= entityType %>/csv-upload" method="POST" enctype="multipart/form-data" id="csvUploadForm">
        <div class="modal-body">
          <div class="csv-upload-zone" id="csvDropZone">
            <i class="bi bi-cloud-arrow-up"></i>
            <p class="mb-1 fw-semibold">Drag & drop your CSV file here</p>
            <p class="text-muted small mb-2">or click to browse</p>
            <input type="file" name="csvFile" id="csvFileInput" accept=".csv" required class="d-none">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('csvFileInput').click()">
              <i class="bi bi-folder2-open me-1"></i>Browse Files
            </button>
            <div id="csvFileName" class="mt-2 text-success fw-semibold d-none"></div>
          </div>

          <div class="mt-3 p-3 rounded" style="background: #f0f4f8; font-size: 0.85rem;">
            <p class="mb-1 fw-semibold" style="color: var(--iit-blue);"><i class="bi bi-info-circle me-1"></i>CSV Format</p>
            <p class="mb-1 text-muted">First row should contain column headers. Expected fields:</p>
            <code class="d-block text-wrap" style="font-size: 0.8rem;"><%= sampleFields %></code>
            <p class="mt-2 mb-0 text-muted small">
              <i class="bi bi-people me-1"></i>For authors/members, use comma-separated emails.
              
            </p>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn" style="background: var(--iit-blue); color: #fff;" id="csvUploadBtn">
            <i class="bi bi-upload me-1"></i>Upload & Import
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
