<% layout('layouts/boilerplate') %>
<div class="mb-3"><a href="/users" class="text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Users</a></div>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h3 class="mb-0"><%= user.first_name %> <%= user.last_name %></h3>
    <span class="badge bg-<%= user.is_active ? 'success' : 'danger' %> fs-6"><%= user.is_active ? 'Active' : 'Inactive' %></span>
  </div>
  <div class="card-body"><div class="row g-4">
    <div class="col-md-8">
      <div class="row g-3">
        <div class="col-sm-6"><strong>Email:</strong> <%= user.email %></div>
        <div class="col-sm-6"><strong>User Type:</strong> <span class="badge bg-secondary"><%= user.user_type %></span></div>
        <% if (user.phone) { %><div class="col-sm-6"><strong>Phone:</strong> <%= user.phone %></div><% } %>
        <div class="col-sm-6"><strong>Joined:</strong> <%= user.date_joined ? new Date(user.date_joined).toLocaleDateString() : '' %></div>
      </div>
      <% if (typeof details !== 'undefined' && details) { %>
      <h5 class="mt-4">Additional Details</h5>
      <div class="row g-3">
        <% Object.entries(details).forEach(([key, val]) => { if (val && !['id','user_id'].includes(key)) { %>
        <div class="col-sm-6"><strong><%= key.replace(/_/g,' ').replace(/\b\w/g, l => l.toUpperCase()) %>:</strong> <%= val %></div>
        <% }}); %>
      </div>
      <% } %>
    </div>
    <div class="col-md-4">
      <div class="d-grid gap-2">
        <a href="/users/<%= user.id %>/edit" class="btn btn-outline-primary"><i class="bi bi-pencil me-2"></i>Edit</a>
        <form method="POST" action="/users/<%= user.id %>/toggle?_method=PUT"><button class="btn btn-outline-<%= user.is_active ? 'warning' : 'success' %> w-100"><%= user.is_active ? 'Deactivate' : 'Activate' %></button></form>
      </div>
    </div>
  </div></div>
</div>
