<% layout('layouts/boilerplate') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>User Management</h2>
  <div><a href="/users/upload" class="btn btn-outline-primary me-2"><i class="bi bi-upload me-1"></i>Bulk Upload</a><a href="/users/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add User</a></div>
</div>
<form method="GET" class="row g-2 mb-4">
  <div class="col-md-4"><input type="text" name="search" class="form-control" placeholder="Search name or email..." value="<%= typeof search !== 'undefined' ? search : '' %>"></div>
  <div class="col-md-3">
    <select name="type" class="form-select"><option value="">All Types</option>
      <% [
        { value: 'admin', label: 'Admin' },
        { value: 'faculty', label: 'Faculty' },
        { value: 'student', label: 'Student' }
      ].forEach(t => { %>
      <option value="<%= t.value %>" <%= typeof selectedType !== 'undefined' && selectedType === t.value ? 'selected' : '' %>><%= t.label %></option><% }); %>
    </select>
  </div>
  <div class="col-md-2">
    <select name="active" class="form-select"><option value="">All Status</option>
      <option value="true" <%= typeof selectedActive !== 'undefined' && selectedActive === 'true' ? 'selected' : '' %>>Active</option>
      <option value="false" <%= typeof selectedActive !== 'undefined' && selectedActive === 'false' ? 'selected' : '' %>>Inactive</option>
    </select>
  </div>
  <div class="col-auto"><button class="btn btn-outline-primary">Filter</button></div>
</form>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover mb-0">
  <thead class="table-light"><tr><th>Name</th><th>Email</th><th>Type</th><th>Status</th><th>Actions</th></tr></thead>
  <tbody>
    <% if (typeof users !== 'undefined' && users.length > 0) { users.forEach(u => { %>
    <tr>
      <td><a href="/users/<%= u.id %>" class="text-decoration-none"><%= u.first_name %> <%= u.last_name %></a></td>
      <td><%= u.email %></td>
      <td><span class="badge bg-secondary"><%= u.user_type %></span></td>
      
      <td><span class="badge bg-<%= u.is_active ? 'success' : 'danger' %>"><%= u.is_active ? 'Active' : 'Inactive' %></span></td>
      <td>
        <a href="/users/<%= u.id %>" class="btn btn-sm btn-outline-primary me-1">View</a>
        <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
        <form method="POST" action="/users/<%= u.id %>/toggle?_method=PUT" class="d-inline"><button class="btn btn-sm btn-outline-<%= u.is_active ? 'warning' : 'success' %>"><%= u.is_active ? 'Deactivate' : 'Activate' %></button></form>
      </td>
    </tr><% }); } else { %><tr><td colspan="5" class="text-center py-4 text-muted">No users found</td></tr><% } %>
  </tbody>
</table></div></div>
<%- include('../partials/pagination') %>
