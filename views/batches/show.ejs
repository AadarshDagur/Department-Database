<% layout('layouts/boilerplate') %>

<div class="mb-4">
  <a href="/batches" class="text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Batches</a>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">CSE-<%= batch.degree %>-<%= batch.year %></h2>
    <p class="text-muted mb-0">CSE Department | <%= batch.degree %> | Year: <%= batch.year %></p>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h5 class="mb-0">Students (<%= students.length %>)</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4">Student</th>
            <th>Entry Number</th>
            <th>Email</th>
            <th class="pe-4 text-end">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (students && students.length > 0) { %>
            <% students.forEach(student => { %>
              <tr class="cursor-pointer" onclick="location.href='/users/<%= student.id %>'">
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <img src="<%= student.profile_image || '/img/default.png' %>" onerror="this.src='/img/default.png'" alt="Profile" class="rounded-circle object-fit-cover" style="width: 40px; height: 40px;">
                    <div>
                      <h6 class="mb-0 text-dark"><%= student.first_name %> <%= student.last_name || '' %></h6>
                    </div>
                  </div>
                </td>
                <td><span class="badge bg-light text-dark border"><%= student.entry_number || 'N/A' %></span></td>
                <td class="text-muted"><%= student.email %></td>
                <td class="pe-4 text-end">
                  <a href="/users/<%= student.id %>" class="btn btn-sm btn-outline-primary" aria-label="View Profile">
                    <i class="bi bi-person-badge"></i> Profile
                  </a>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="4" class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-3 text-secondary"></i>
                No students enrolled in this batch yet.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>