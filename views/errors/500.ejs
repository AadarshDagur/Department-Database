<% layout('layouts/boilerplate') %>
<div class="text-center py-5">
  <h1 class="display-1 text-muted">500</h1>
  <h3>Something went wrong</h3>
  <p class="text-muted">An unexpected error occurred. Please try again later.</p>
  <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV !== 'production') { %><pre class="text-start bg-light p-3 rounded mt-4"><%= error.stack || error.message || error %></pre><% } %>
  <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house me-1"></i>Go Home</a>
</div>
