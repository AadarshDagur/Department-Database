<% layout('layouts/boilerplate') %>
<div class="mb-3"><a href="/projects" class="text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Projects</a></div>
<div class="card border-0 shadow-sm"><div class="card-header bg-white"><h3 class="mb-0"><%= item ? 'Edit Project' : 'New Project' %></h3></div>
  <div class="card-body">
    <form method="POST" action="<%= item ? '/projects/' + item.id + '?_method=PUT' : '/projects' %>">
      <div class="row g-3">
        <div class="col-12"><label class="form-label">Title *</label><input type="text" class="form-control" name="title" value="<%= item ? item.title : '' %>" required></div>
        <div class="col-12"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4"><%= item ? (item.description || '') : '' %></textarea></div>
        <div class="col-md-6"><label class="form-label">Project Code</label><input type="text" class="form-control" name="code" value="<%= item ? (item.code || '') : '' %>"></div>
        <div class="col-md-6"><label class="form-label">Status</label><select class="form-select" name="status"><% statusChoices.forEach(s => { %><option value="<%= s %>" <%= item && item.status === s ? 'selected' : '' %>><%= s %></option><% }); %></select></div>
        <div class="col-md-4"><label class="form-label">Investment (₹)</label><input type="number" step="0.01" class="form-control" name="investment" value="<%= item ? (item.investment || '') : '' %>"></div>
        <div class="col-md-4"><label class="form-label">Start Date</label><input type="date" class="form-control" name="start_date" value="<%= item && item.start_date ? new Date(item.start_date).toISOString().split('T')[0] : '' %>"></div>
        <div class="col-md-4"><label class="form-label">End Date</label><input type="date" class="form-control" name="end_date" value="<%= item && item.end_date ? new Date(item.end_date).toISOString().split('T')[0] : '' %>"></div>
        <div class="col-12"><label class="form-label">URL</label><input type="url" class="form-control" name="url" value="<%= item ? (item.url || '') : '' %>"></div>
        <div class="col-12"><label class="form-label" for="projectMembersSearch">Members (Faculty)</label>
          <input type="search" id="projectMembersSearch" class="form-control mb-2" placeholder="Search members by name..." data-filter-target="projectMembersSelect" autocomplete="off">
          <select id="projectMembersSelect" class="form-select searchable-multiselect" name="members" multiple size="5"><% users.forEach(u => { %><option value="<%= u.id %>" <%= item && item.members && item.members.some(m => m.id === u.id) ? 'selected' : '' %>><%= u.first_name %> <%= u.last_name %></option><% }); %></select>
          <small class="text-muted">Type to filter, then hold Ctrl/Cmd to select multiple members</small>
        </div>
  </div>
</div>
