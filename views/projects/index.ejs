<% layout('layouts/boilerplate') %>
<div class="page-header">
  <div>
    <h2 class="mb-1"><i class="bi bi-folder2-open me-2"></i>Projects</h2>
    <p class="text-muted mb-0">Browse research projects</p>
  </div>
  <% if (currentUser && ['faculty','admin'].includes(currentUser.user_type)) { %>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/projects/my" class="action-btn">My Projects</a>
      <a href="/projects/drafts" class="action-btn">Drafts</a>
      <button class="action-btn" data-bs-toggle="modal" data-bs-target="#csvUploadModal"><i class="bi bi-upload me-1"></i>CSV Upload</button>
      <a href="/projects/new" class="action-btn action-btn-primary"><i class="bi bi-plus-lg me-1"></i>New</a>
    </div>
  <% } %>
</div>
<div class="filter-bar">
  <form class="row g-2" method="GET">
    <div class="col-md-5"><input type="text" class="form-control" name="search" placeholder="Search..." value="<%= query.search || '' %>"></div>
    <div class="col-md-3"><select class="form-select" name="type"><option value="">All Status</option><% ['Ongoing','Completed','Cancelled'].forEach(t => { %><option value="<%= t %>" <%= query.type === t ? 'selected' : '' %>><%= t %></option><% }); %></select></div>
    <div class="col-md-2"><a href="/projects" class="btn btn-outline-secondary w-100">Clear</a></div>
  </form>
</div>
<div class="table-container"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
  <thead><tr><th>Title</th><th>Code</th><th>Status</th><th>Created By</th><th>Date</th><th></th></tr></thead>
  <tbody>
    <% if (items.length === 0) { %><tr><td colspan="6" class="text-center py-5"><div class="empty-state"><i class="bi bi-folder2-open"></i><p>No projects found</p></div></td></tr><% } %>
    <% items.forEach(item => { %>
    <tr>
      <td><a href="/projects/<%= item.id %>" class="text-decoration-none fw-medium" style="color: var(--iit-blue);"><%= item.title %></a></td>
      <td><code><%= item.code || '-' %></code></td>
      <td><span class="badge badge-status-<%= item.status === 'Ongoing' ? 'pending' : item.status === 'Completed' ? 'approved' : 'rejected' %>"><%= item.status %></span></td>
      <td class="text-muted"><%= item.creator_name || '' %></td>
      <td class="text-muted"><%= item.created_date ? new Date(item.created_date).toLocaleDateString() : '' %></td>
      <td><a href="/projects/<%= item.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
    </tr>
    <% }); %>
  </tbody>
</table></div></div>
<%- include('../partials/pagination') %>
<%- include('../partials/csv-upload-modal', { entityType: 'projects', sampleFields: 'title, description, code, status, investment, start_date, end_date, url, members' }) %>
