<% layout('layouts/boilerplate') %>

<div class="page-header">
  <div>
    <h2 class="mb-1">Dashboard</h2>
    <p class="text-muted mb-0">Welcome back, <%= currentUser.first_name %></p>
  </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
  <% const cards = [
    { label: 'Publications', count: counts.publications || 0, icon: 'bi-journal-text', variant: 'blue', href: '/publications' },
    { label: 'Projects', count: counts.projects || 0, icon: 'bi-folder2-open', variant: 'green', href: '/projects' },
    { label: 'Events', count: counts.events || 0, icon: 'bi-calendar-event', variant: 'purple', href: '/events' },
    { label: 'Achievements', count: counts.achievements || 0, icon: 'bi-trophy', variant: 'amber', href: '/achievements' },
    { label: 'Visits', count: counts.visits || 0, icon: 'bi-airplane', variant: 'teal', href: '/visits' },
    { label: 'Student Projects', count: counts.studentProjects || 0, icon: 'bi-mortarboard', variant: 'rose', href: '/student-projects' },
    { label: 'Research Labs', count: counts.researchLabs || 0, icon: 'bi-pc-display', variant: 'slate', href: '/research-labs' },
  ]; %>
  <% cards.forEach(card => { %>
    <div class="col-6 col-md-4 col-xl-3">
      <a href="<%= card.href %>" class="text-decoration-none">
        <div class="stat-card stat-card-<%= card.variant %>">
          <div class="stat-icon"><i class="bi <%= card.icon %>"></i></div>
          <div class="stat-value"><%= card.count %></div>
          <div class="stat-label"><%= card.label %></div>
        </div>
      </a>
    </div>
  <% }); %>
</div>

<!-- Pending approvals (for faculty advisor verification) -->
<% if (pendingCounts && Object.keys(pendingCounts).length > 0) { %>
<div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid var(--iit-gold) !important;">
  <div class="card-header border-0" style="background: rgba(212,160,23,0.08);">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0" style="color: var(--iit-blue);"><i class="bi bi-clock-history me-2"></i>Pending Approvals</h5>
      <a href="/approvals" class="action-btn action-btn-sm">Open Approval Center</a>
    </div>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <% if (pendingCounts.publications) { %>
        <div class="col-auto"><a href="/publications/pending" class="btn btn-outline-warning">Publications <span class="badge bg-warning text-dark"><%= pendingCounts.publications %></span></a></div>
      <% } %>
      <% if (pendingCounts.projects) { %>
        <div class="col-auto"><a href="/projects/pending" class="btn btn-outline-warning">Projects <span class="badge bg-warning text-dark"><%= pendingCounts.projects %></span></a></div>
      <% } %>
      <% if (pendingCounts.events) { %>
        <div class="col-auto"><a href="/events/pending" class="btn btn-outline-warning">Events <span class="badge bg-warning text-dark"><%= pendingCounts.events %></span></a></div>
      <% } %>
      <% if (pendingCounts.achievements) { %>
        <div class="col-auto"><a href="/achievements/pending" class="btn btn-outline-warning">Achievements <span class="badge bg-warning text-dark"><%= pendingCounts.achievements %></span></a></div>
      <% } %>
      <% if (pendingCounts.visits) { %>
        <div class="col-auto"><a href="/visits/pending" class="btn btn-outline-warning">Visits <span class="badge bg-warning text-dark"><%= pendingCounts.visits %></span></a></div>
      <% } %>
      <% if (pendingCounts.studentProjects) { %>
        <div class="col-auto"><a href="/student-projects/pending" class="btn btn-outline-warning">Student Projects <span class="badge bg-warning text-dark"><%= pendingCounts.studentProjects %></span></a></div>
      <% } %>
      <% if (!pendingCounts.publications && !pendingCounts.projects && !pendingCounts.events && !pendingCounts.achievements && !pendingCounts.visits && !pendingCounts.studentProjects) { %>
        <div class="col"><p class="text-muted mb-0">No pending items</p></div>
      <% } %>
    </div>
  </div>
</div>
<% } %>

<div class="row g-4">
  <!-- Recent Publications -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0" style="color: var(--iit-blue);"><i class="bi bi-journal-text me-2"></i>Recent Publications</h5>
        <a href="/publications" class="action-btn action-btn-sm">View All</a>
      </div>
      <div class="list-group list-group-flush">
        <% if (recentPubs.length === 0) { %>
          <div class="list-group-item text-muted text-center py-4">
            <i class="bi bi-journal-text d-block mb-2" style="font-size: 1.5rem; opacity: 0.3;"></i>No publications yet
          </div>
        <% } %>
        <% recentPubs.forEach(pub => { %>
          <a href="/publications/<%= pub.id %>" class="list-group-item list-group-item-action">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h6 class="mb-1"><%= pub.title %></h6>
                <span class="badge badge-type"><%= pub.publication_type %></span>
              </div>
              <small class="text-muted"><%= pub.created_date ? new Date(pub.created_date).toLocaleDateString() : '' %></small>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Recent Events -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
        <h5 class="mb-0" style="color: var(--iit-blue);"><i class="bi bi-calendar-event me-2"></i>Recent Events</h5>
        <a href="/events" class="action-btn action-btn-sm">View All</a>
      </div>
      <div class="list-group list-group-flush">
        <% if (recentEvents.length === 0) { %>
          <div class="list-group-item text-muted text-center py-4">
            <i class="bi bi-calendar-event d-block mb-2" style="font-size: 1.5rem; opacity: 0.3;"></i>No events yet
          </div>
        <% } %>
        <% recentEvents.forEach(evt => { %>
          <a href="/events/<%= evt.id %>" class="list-group-item list-group-item-action">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h6 class="mb-1"><%= evt.title %></h6>
                <span class="badge badge-type"><%= evt.event_type %></span>
              </div>
              <small class="text-muted"><%= evt.start_date ? new Date(evt.start_date).toLocaleDateString() : '' %></small>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</div>
