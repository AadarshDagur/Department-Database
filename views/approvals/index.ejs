<% layout('layouts/boilerplate') %>

<div class="page-header">
  <div>
    <h2 class="mb-1"><i class="bi bi-check2-square me-2"></i>Faculty Advisor Approvals</h2>
    <p class="text-muted mb-0">Review and verify pending submissions from your advisees</p>
  </div>
  <span class="pending-badge"><i class="bi bi-clock-history"></i><%= totalPending %> Pending</span>
</div>

<% if (totalPending === 0) { %>
  <div class="empty-state">
    <i class="bi bi-check-circle"></i>
    <p class="mb-0">No pending requests right now</p>
  </div>
<% } %>

<% sections.forEach(section => { %>
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0"><%= section.label %></h5>
      <span class="badge badge-status-pending"><%= section.count %> Pending</span>
    </div>
    <div class="card-body p-0">
      <% if (section.items.length === 0) { %>
        <div class="p-4 text-center text-muted">No pending <%= section.label.toLowerCase() %></div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Title</th>
                <th>Submitted By</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% section.items.forEach(item => { %>
                <tr>
                  <td><a href="<%= section.path %>/<%= item.id %>" class="text-decoration-none"><%= item.title %></a></td>
                  <td><%= item.creator_name || 'Unknown' %></td>
                  <td class="text-muted"><%= item.created_date ? new Date(item.created_date).toLocaleDateString() : '' %></td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <a href="<%= section.path %>/<%= item.id %>" class="btn btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                      <form method="POST" action="<%= section.path %>/<%= item.id %>/approve?_method=PUT" class="d-inline">
                        <button class="btn btn-outline-success" title="Approve"><i class="bi bi-check-lg"></i></button>
                      </form>
                      <form method="POST" action="<%= section.path %>/<%= item.id %>/reject?_method=PUT" class="d-inline">
                        <button class="btn btn-outline-danger" title="Reject"><i class="bi bi-x-lg"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
<% }); %>
