<% layout('layouts/boilerplate') %>
<div class="page-header">
  <h2><i class="bi bi-inboxes"></i>Query Requests</h2>
  <a href="/queries/new" class="btn btn-outline-primary">
    <i class="bi bi-send me-1"></i>Submit Query
  </a>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/queries" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option value="">All</option>
          <% ['Unresolved', 'Resolved'].forEach(s => { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Category</label>
        <select name="category" class="form-select">
          <option value="">All</option>
          <% ['Bug', 'Feature Request', 'General', 'Other'].forEach(c => { %>
            <option value="<%= c %>" <%= filters.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Search</label>
        <input type="text" name="q" value="<%= filters.q %>" class="form-control" placeholder="Search subject or description">
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-primary" type="submit">Filter</button>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (items && items.length > 0) { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Subject</th>
              <th>Requester</th>
              <th>Category</th>
              <th>Status</th>
              <th>Created</th>
              <th>Response</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(item => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= item.subject %></div>
                  <div class="small text-muted"><%= item.description ? item.description.slice(0, 120) : '' %></div>
                  <% if (item.screenshot) { %>
                    <a href="<%= item.screenshot %>" target="_blank" class="small">View screenshot</a>
                  <% } %>
                </td>
                <td>
                  <div><%= item.requester_name || 'Anonymous' %></div>
                  <div class="small text-muted"><%= item.requester_email || '' %></div>
                </td>
                <td><span class="badge text-bg-light border"><%= item.category || 'General' %></span></td>
                <td>
                  <span class="badge <%= item.query_status === 'Resolved' ? 'text-bg-success' : 'text-bg-warning' %>">
                    <%= item.query_status %>
                  </span>
                </td>
                <td><%= item.created_at ? new Date(item.created_at).toLocaleString() : '' %></td>
                <td>
                  <% if (item.query_status === 'Resolved') { %>
                    <span class="text-muted small">Already responded</span>
                  <% } else { %>
                    <form method="POST" action="/queries/<%= item.id %>/respond" class="d-grid gap-2" style="min-width: 260px;">
                      <textarea name="response_message" class="form-control form-control-sm" rows="2" placeholder="Write response to user" required></textarea>
                      <button type="submit" class="btn btn-sm btn-outline-primary">Send Response</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state m-4">
        <i class="bi bi-inbox"></i>
        <p class="mb-0">No queries found</p>
      </div>
    <% } %>
  </div>
</div>
