<% layout('layouts/boilerplate') %>

<div class="mb-3">
  <a href="/publications" class="text-decoration-none" style="color: var(--iit-blue);"><i class="bi bi-arrow-left me-1"></i>Back to Publications</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center" style="border-bottom: 2px solid var(--iit-blue);">
    <h3 class="mb-0" style="color: var(--iit-blue);"><%= item.title %></h3>
    <div>
      <% if (item.is_draft) { %><span class="badge badge-status-draft">Draft</span>
      <% } else if (item.object_type === 'P') { %><span class="badge badge-status-pending">Pending</span>
      <% } else if (item.is_deleted) { %><span class="badge badge-status-rejected">Deleted</span>
      <% } else { %><span class="badge badge-status-approved">Active</span><% } %>
    </div>
  </div>
  <div class="card-body">
    <div class="row g-4">
      <div class="col-md-8">
        <% if (item.description) { %>
          <h5>Description</h5>
          <p><%= item.description %></p>
        <% } %>

        <div class="row g-3">
          <% if (item.publication_type) { %><div class="col-sm-6"><span class="detail-label">Type:</span> <span class="detail-value"><%= item.publication_type %></span></div><% } %>
          <% if (item.status) { %><div class="col-sm-6"><span class="detail-label">Status:</span> <span class="detail-value"><%= item.status %></span></div><% } %>
          <% if (item.journal_name) { %><div class="col-sm-6"><span class="detail-label">Journal:</span> <span class="detail-value"><%= item.journal_name %></span></div><% } %>
          <% if (item.publisher) { %><div class="col-sm-6"><span class="detail-label">Publisher:</span> <span class="detail-value"><%= item.publisher %></span></div><% } %>
          <% if (item.doi) { %><div class="col-sm-6"><span class="detail-label">DOI:</span> <span class="detail-value"><%= item.doi %></span></div><% } %>
          <% if (item.isbn) { %><div class="col-sm-6"><span class="detail-label">ISBN:</span> <span class="detail-value"><%= item.isbn %></span></div><% } %>
          <% if (item.issn) { %><div class="col-sm-6"><span class="detail-label">ISSN:</span> <span class="detail-value"><%= item.issn %></span></div><% } %>
          <% if (item.volume) { %><div class="col-sm-6"><span class="detail-label">Volume:</span> <span class="detail-value"><%= item.volume %></span></div><% } %>
          <% if (item.pages) { %><div class="col-sm-6"><span class="detail-label">Pages:</span> <span class="detail-value"><%= item.pages %></span></div><% } %>
          <% if (item.year) { %><div class="col-sm-6"><span class="detail-label">Year:</span> <span class="detail-value"><%= item.year %></span></div><% } %>
          <% if (item.url) { %><div class="col-12"><span class="detail-label">URL:</span> <a href="<%= item.url %>" target="_blank" style="color: var(--iit-blue);"><%= item.url %></a></div><% } %>
        </div>

        <% if (item.members && item.members.length > 0) { %>
          <h5 class="mt-4">Authors</h5>
          <div class="d-flex flex-wrap gap-2">
            <% item.members.forEach(m => { %>
              <span class="badge bg-light text-dark border"><%= m.first_name %> <%= m.last_name %></span>
            <% }); %>
          </div>
        <% } %>

      </div>

      <div class="col-md-4">
        <div class="card bg-light border-0">
          <div class="card-body">
            <h6>Details</h6>
            <p class="mb-1"><strong>Created by:</strong> <%= item.creator_name || 'Unknown' %></p>
            <p class="mb-1">
              <strong>Authors:</strong>
              <% if (item.members && item.members.length > 0) { %>
                <%= item.members.map(m => `${m.first_name} ${m.last_name}`).join(', ') %>
              <% } else { %>
                <%= item.creator_name || 'Unknown' %>
              <% } %>
            </p>
            <p class="mb-1"><strong>Created:</strong> <%= item.created_date ? new Date(item.created_date).toLocaleString() : 'N/A' %></p>
            <% if (item.published_date) { %><p class="mb-1"><strong>Published:</strong> <%= new Date(item.published_date).toLocaleDateString() %></p><% } %>
            <% if (item.accepted_date) { %><p class="mb-1"><strong>Accepted:</strong> <%= new Date(item.accepted_date).toLocaleDateString() %></p><% } %>
          </div>
        </div>

        <% if (currentUser && (item.created_by === currentUser.id || ['admin'].includes(currentUser.user_type))) { %>
          <div class="d-grid gap-2 mt-3">
            <% if (!item.is_deleted) { %>
              <a href="/publications/<%= item.id %>/edit" class="btn btn-outline-primary"><i class="bi bi-pencil me-2"></i>Edit</a>
              <form method="POST" action="/publications/<%= item.id %>?_method=DELETE" onsubmit="return confirm('Delete this publication?')">
                <button class="btn btn-outline-danger w-100"><i class="bi bi-trash me-2"></i>Delete</button>
              </form>
            <% } else { %>
              <form method="POST" action="/publications/<%= item.id %>/restore?_method=PUT">
                <button class="btn btn-outline-success w-100"><i class="bi bi-arrow-counterclockwise me-2"></i>Restore</button>
              </form>
            <% } %>
            <% if (item.is_draft) { %>
              <form method="POST" action="/publications/<%= item.id %>/submit?_method=PUT">
                <button class="btn btn-success w-100"><i class="bi bi-send me-2"></i>Submit for Approval</button>
              </form>
            <% } %>
          </div>
        <% } %>

        <% if (currentUser && ['faculty', 'admin'].includes(currentUser.user_type) && item.object_type === 'P') { %>
        <div class="card mt-3 border-warning">
          <div class="card-header bg-warning bg-opacity-10 text-warning-emphasis"><strong><i class="bi bi-exclamation-triangle me-2"></i>Pending Approval</strong></div>
          <div class="card-body">
            <p class="small text-muted mb-3">This submission requires review.</p>
            <div class="d-flex flex-column gap-2">
              <form method="POST" action="/publications/<%= item.id %>/approve?_method=PUT">
                <button class="btn btn-success w-100"><i class="bi bi-check-lg me-2"></i>Approve</button>
              </form>
              <form method="POST" action="/publications/<%= item.id %>/reject?_method=PUT">
                <button class="btn btn-danger w-100"><i class="bi bi-x-lg me-2"></i>Reject</button>
              </form>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
