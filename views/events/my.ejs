<% layout('layouts/boilerplate') %>
<div class="d-flex justify-content-between align-items-center mb-4"><h2><i class="bi bi-calendar-event me-2"></i>My Events</h2><a href="/events/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New</a></div>
<ul class="nav nav-tabs mb-4">
  <li class="nav-item"><a class="nav-link <%= tab === 'active' ? 'active' : '' %>" href="/events/my">Active</a></li>
  <li class="nav-item"><a class="nav-link <%= tab === 'drafts' ? 'active' : '' %>" href="/events/drafts">Drafts</a></li>
  <li class="nav-item"><a class="nav-link <%= tab === 'pending' ? 'active' : '' %>" href="/events/pending">Pending</a></li>
  <li class="nav-item"><a class="nav-link <%= tab === 'deleted' ? 'active' : '' %>" href="/events/deleted">Deleted</a></li>
</ul>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0">
  <thead class="table-light"><tr><th>Title</th><th>Type</th><th>State</th><th>Date</th><th>Actions</th></tr></thead>
  <tbody>
    <% if (items.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-4">No items</td></tr><% } %>
    <% items.forEach(item => { %><tr>
      <td><a href="/events/<%= item.id %>" class="text-decoration-none"><%= item.title %></a></td>
      <td><span class="badge bg-info"><%= item.event_type %></span></td>
      <td><% if (item.is_draft) { %><span class="badge bg-secondary">Draft</span><% } else if (item.object_type === 'P') { %><span class="badge bg-warning">Pending</span><% } else if (item.is_deleted) { %><span class="badge bg-dark">Deleted</span><% } else { %><span class="badge bg-success">Active</span><% } %></td>
      <td class="text-muted"><%= item.created_date ? new Date(item.created_date).toLocaleDateString() : '' %></td>
      <td><div class="btn-group btn-group-sm">
        <a href="/events/<%= item.id %>" class="btn btn-outline-primary"><i class="bi bi-eye"></i></a>
        <% if (!item.is_deleted) { %><a href="/events/<%= item.id %>/edit" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i></a><% } %>
        <% if (item.is_draft) { %><form method="POST" action="/events/<%= item.id %>/submit?_method=PUT" class="d-inline"><button class="btn btn-outline-success btn-sm"><i class="bi bi-send"></i></button></form><% } %>
        <% if (tab === 'pending' && ['faculty'].includes(currentUser.user_type)) { %>
          <form method="POST" action="/events/<%= item.id %>/approve?_method=PUT" class="d-inline"><button class="btn btn-outline-success btn-sm"><i class="bi bi-check-lg"></i></button></form>
          <form method="POST" action="/events/<%= item.id %>/reject?_method=PUT" class="d-inline"><button class="btn btn-outline-danger btn-sm"><i class="bi bi-x-lg"></i></button></form>
        <% } %>
        <% if (item.is_deleted) { %><form method="POST" action="/events/<%= item.id %>/restore?_method=PUT" class="d-inline"><button class="btn btn-outline-info btn-sm"><i class="bi bi-arrow-counterclockwise"></i></button></form><% } else if (!item.is_draft) { %><form method="POST" action="/events/<%= item.id %>?_method=DELETE" class="d-inline" onsubmit="return confirm('Delete?')"><button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button></form><% } %>
      </div></td>
    </tr><% }); %>
  </tbody>
</table></div></div>
<%- include('../partials/pagination') %>
