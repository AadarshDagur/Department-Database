<% layout('layouts/boilerplate') %>

<div class="auth-page" style="margin-left: 0 !important;">
  <div class="auth-card">
    <div class="text-center mb-4">
      <img src="/img/logo.png" alt="IIT Ropar" class="auth-logo">
      <h3 class="mt-2 fw-bold" style="color: var(--iit-blue);">Password Login</h3>
    </div>
    <%- include('../partials/flash') %>
    <form action="/login-password" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email Address</label>
        <input type="email" class="form-control" id="email" name="email" required autofocus>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password</label>
        <input type="password" class="form-control" id="password" name="password" required>
      </div>
      <button type="submit" class="btn w-100 mb-3" style="background: var(--iit-blue); color: #fff;">Login</button>
    </form>
    <div class="text-center">
      <a href="/login" class="text-decoration-none" style="color: var(--iit-blue);">Login with OTP instead</a>
    </div>
  </div>
</div>
