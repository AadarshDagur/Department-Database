<% layout('layouts/boilerplate') %>

<div class="auth-page" style="margin-left: 0 !important;">
  <div class="auth-card">
    <div class="text-center mb-4">
      <img src="/img/logo.png" alt="IIT Ropar" class="auth-logo">
      <h3 class="mt-2 fw-bold" style="color: var(--iit-blue);">Verify OTP</h3>
      <p class="text-muted">Enter the code sent to <strong><%= email %></strong></p>
    </div>
    <%- include('../partials/flash') %>
    <form action="/verify-otp" method="POST">
      <div class="mb-3">
        <label for="otp" class="form-label fw-semibold">OTP Code</label>
        <input type="text" class="form-control form-control-lg text-center" id="otp" name="otp" 
               maxlength="6" pattern="[0-9]{6}" required autofocus placeholder="000000"
               style="letter-spacing: 8px; font-size: 1.5rem;">
      </div>
      <button type="submit" class="btn w-100 mb-3" style="background: var(--iit-blue); color: #fff;">
        <i class="bi bi-check-circle me-2"></i>Verify
      </button>
    </form>
    <div class="text-center">
      <a href="/login" class="text-decoration-none" style="color: var(--iit-blue);">
        <i class="bi bi-arrow-left me-1"></i>Back to login
      </a>
    </div>
  </div>
</div>
