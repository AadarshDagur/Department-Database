<% layout('layouts/boilerplate') %>

<div class="auth-page" style="margin-left: 0 !important;">
  <div class="auth-card">
    <div class="text-center mb-4">
      <img src="/img/logo.png" alt="IIT Ropar" class="auth-logo">
      <h3 class="mt-2 fw-bold" style="color: var(--iit-blue);">Login with OTP</h3>
      <p class="text-muted">Enter your email to receive a one-time password</p>
    </div>
    <%- include('../partials/flash') %>
    <form action="/login" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email Address</label>
        <input type="email" class="form-control" id="email" name="email" required autofocus placeholder="you@iitrpr.ac.in">
      </div>
      <button type="submit" class="btn w-100 mb-3" style="background: var(--iit-blue); color: #fff;">
        <i class="bi bi-envelope me-2"></i>Send OTP
      </button>
    </form>
    <div class="text-center">
      <a href="/login-password" class="text-decoration-none" style="color: var(--iit-blue);">Login with password instead</a>
    </div>
  </div>
</div>
