<% layout('layouts/boilerplate') %>
<div class="mb-3"><a href="/student-projects/my" class="text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to My Student Projects</a></div>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><h3 class="mb-0"><%= item ? 'Edit Student Project' : 'Add Student Project' %></h3></div>
  <div class="card-body">
    <% const isEdit = !!item; const action = isEdit ? '/student-projects/' + item.id + '?_method=PUT' : '/student-projects'; %>
    <form method="POST" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-8"><label class="form-label">Title *</label><input type="text" name="title" class="form-control" value="<%= isEdit ? item.title : '' %>" required></div>
        <div class="col-md-4"><label class="form-label">Status *</label>
          <select name="status" class="form-select" required><option value="">Select Status</option>
            <% ['Ongoing','Completed','Cancelled'].forEach(t => { %><option value="<%= t %>" <%= isEdit && item.status === t ? 'selected' : '' %>><%= t %></option><% }); %>
          </select>
        </div>
        <div class="col-12"><label class="form-label">Description</label><textarea name="description" class="form-control" rows="4"><%= isEdit ? (item.description || '') : '' %></textarea></div>
        <div class="col-md-6"><label class="form-label">Mentor</label>
          <select name="mentor_id" class="form-select"><option value="">Select Mentor</option>
            <% if (typeof faculty !== 'undefined') { faculty.forEach(f => { %><option value="<%= f.id %>" <%= isEdit && item.mentor_id == f.id ? 'selected' : '' %>><%= f.first_name %> <%= f.last_name %></option><% }); } %>
          </select>
        </div>
        <div class="col-md-3"><label class="form-label">Start Date</label><input type="date" name="start_date" class="form-control" value="<%= isEdit && item.start_date ? new Date(item.start_date).toISOString().split('T')[0] : '' %>"></div>
        <div class="col-md-3"><label class="form-label">End Date</label><input type="date" name="end_date" class="form-control" value="<%= isEdit && item.end_date ? new Date(item.end_date).toISOString().split('T')[0] : '' %>"></div>
        <div class="col-md-6"><label class="form-label">URL</label><input type="url" name="url" class="form-control" value="<%= isEdit ? (item.url || '') : '' %>"></div>
        <div class="col-md-6"><label class="form-label" for="studentsSearch">Student Members</label> 
          <input type="search" id="studentsSearch" class="form-control mb-2" placeholder="Search students by name..." data-filter-target="studentsSelect" autocomplete="off">
          <select id="studentsSelect" name="members" class="form-select searchable-multiselect" multiple size="5">
            <% if (typeof students !== 'undefined') { students.forEach(u => { %><option value="<%= u.id %>" <%= isEdit && item.memberIds && item.memberIds.includes(u.id) ? 'selected' : '' %>><%= u.first_name %> <%= u.last_name %></option><% }); } %>
          </select><small class="text-muted">Type to filter, then hold Ctrl/Cmd to select multiple members</small>
        </div>
        </div>
        <div class="col-12 mt-4">
          <button type="submit" name="is_draft" value="false" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Save</button>
          <button type="submit" name="is_draft" value="true" class="btn btn-outline-secondary me-2"><i class="bi bi-file-earmark me-1"></i>Save as Draft</button>
          <a href="/student-projects/my" class="btn btn-light">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>
