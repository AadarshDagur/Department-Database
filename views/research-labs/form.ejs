<% layout('layouts/boilerplate') %>
<div class="mb-3"><a href="/research-labs" class="text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Research Labs</a></div>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white"><h3 class="mb-0"><%= item ? 'Edit Research Lab' : 'Add Research Lab' %></h3></div>
  <div class="card-body">
    <% const isEdit = !!item; const action = isEdit ? '/research-labs/' + item.id + '?_method=PUT' : '/research-labs'; %>
    <form method="POST" action="<%= action %>">
      <div class="row g-3">
        <div class="col-md-8"><label class="form-label">Name *</label><input type="text" name="name" class="form-control" value="<%= isEdit ? item.name : '' %>" required></div>
        <div class="col-md-4"><label class="form-label">Lab Type *</label>
          <select name="lab_type" class="form-select" required><option value="">Select Type</option>
            <% ['UG Lab','PG Lab','Research Lab'].forEach(t => { %><option value="<%= t %>" <%= isEdit && item.lab_type === t ? 'selected' : '' %>><%= t %></option><% }); %>
          </select>
        </div>
        <div class="col-md-4"><label class="form-label">Code</label><input type="text" name="code" class="form-control" value="<%= isEdit ? (item.code || '') : '' %>"></div>
        <div class="col-md-4"><label class="form-label">Head</label>
          <select name="head_id" class="form-select"><option value="">Select Head</option>
            <% if (typeof faculty !== 'undefined') { faculty.forEach(f => { %><option value="<%= f.id %>" <%= isEdit && item.head_id == f.id ? 'selected' : '' %>><%= f.first_name %> <%= f.last_name %></option><% }); } %>
          </select>
        </div>
        <div class="col-md-4"><label class="form-label">Website</label><input type="url" name="website" class="form-control" value="<%= isEdit ? (item.website || '') : '' %>"></div>
        <div class="col-12"><label class="form-label">Description</label><textarea name="description" class="form-control" rows="4"><%= isEdit ? (item.description || '') : '' %></textarea></div>
        <div class="col-12"><label class="form-label">Equipment</label><textarea name="equipment" class="form-control" rows="3"><%= isEdit ? (item.equipment || '') : '' %></textarea></div>
        <div class="col-12"><label class="form-label">Address</label><input type="text" name="address" class="form-control" value="<%= isEdit ? (item.address || '') : '' %>"></div>
        <div class="col-md-6"><label class="form-label">Members</label>
          <select name="members" class="form-select" multiple size="5">
            <% if (typeof users !== 'undefined') { users.forEach(u => { %><option value="<%= u.id %>" <%= isEdit && item.memberIds && item.memberIds.includes(u.id) ? 'selected' : '' %>><%= u.first_name %> <%= u.last_name %></option><% }); } %>
          </select><small class="text-muted">Hold Ctrl to select multiple</small>
        </div>
        </div>
        <div class="col-12 mt-4">
          <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Save</button>
          <a href="/research-labs" class="btn btn-light">Cancel</a>
        </div>
      </div>
    </form>
  </div>
</div>
